# ─── TaxWijs Production Environment ────────────────────────────────────────────
# Copy to .env and fill in ALL values before deploying.

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-50-chars-min
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=taxwijs
POSTGRES_USER=taxwijs
POSTGRES_PASSWORD=change-me-strong-password
# DATABASE_URL is constructed from the above in docker-compose.yml
# If running without Docker, set explicitly:
# DATABASE_URL=postgres://taxwijs:password@localhost:5432/taxwijs

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── AI providers ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...      # For Claude chat (Phase 4)
OPENAI_API_KEY=sk-...                  # For RAG embeddings (Phase 2)

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...             # Your monthly premium price ID

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://yourdomain.com
FREE_DAILY_LIMIT=10
ANON_SESSION_LIMIT=5

# ── Frontend build vars (Vite — must be set BEFORE npm run build) ─────────────
# Leave VITE_API_URL blank if frontend + backend are on the same domain (Railway nixpacks).
VITE_API_URL=
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
VITE_ANON_SESSION_LIMIT=5

# ── File storage (uploaded client documents) ─────────────────────────────────
# REQUIRED in production. "local" stores on Railway's ephemeral filesystem —
# every deploy silently destroys uploaded documents. Use an S3-compatible
# bucket (AWS S3, Cloudflare R2, Backblaze B2) so files survive deploys.
FILE_STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me
AWS_STORAGE_BUCKET_NAME=taxwijs-documents
AWS_S3_REGION_NAME=eu-central-1
AWS_S3_ENDPOINT_URL=

# ── Security ──────────────────────────────────────────────────────────────────
SECURE_SSL_REDIRECT=True

# ── Reddit (optional — for Phase 1 forum scraper) ────────────────────────────
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=

# Copy this file to .env and fill in your keys.
# Never commit .env to git.

# Phase 2 — embeddings (vector search)
OPENAI_API_KEY=sk-...

# Phase 4 — AI responses (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# BSN encryption key — Required: generate with:
#   python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
BSN_ENCRYPTION_KEY=

# Phase 1 scrapers (optional — only needed to re-scrape)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Phase 2 production vector store (optional at this stage)
SUPABASE_URL=
SUPABASE_KEY=

# Stripe (premium payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
FRONTEND_URL=http://localhost:5173

# Phase 5 — Document OCR provider
# Options: none (default) | google_vision | google_document_ai | azure
OCR_PROVIDER=none
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_DOCAI_PROJECT_ID=
GOOGLE_DOCAI_LOCATION=eu
GOOGLE_DOCAI_PROCESSOR_ID=
AZURE_FORM_RECOGNIZER_ENDPOINT=
AZURE_FORM_RECOGNIZER_KEY=

# Phase 6 — File storage (uploaded client documents)
# Options: local (default — NOT durable on Railway, wiped every deploy) | s3
FILE_STORAGE_PROVIDER=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=eu-central-1
AWS_S3_ENDPOINT_URL=

# Phase 6 — Monitoring
SENTRY_DSN=

# Phase 6 — Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@taxwijs.nl
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=TaxWijs <noreply@taxwijs.nl>

# Leave blank in local dev — Vite proxies /api to http://localhost:8000 automatically.
# In production (Railway monolith), also leave blank — frontend and backend share the same
# origin so /api routes work without a full URL.  Only set this if API is on a separate domain.
VITE_API_URL=

# Google OAuth — get this from Google Cloud Console → Credentials → OAuth 2.0 Client ID
# Authorized JS origins must include: http://localhost:5173 (dev), https://taxwijs.nl (prod)
VITE_GOOGLE_CLIENT_ID=1051653351506-a9e3982dr3tujce671eteo94hkbgb20i.apps.googleusercontent.com

# Version control
.git/
.gitignore

# Local env / secrets (never bake into image)
.env
*.env.local
.env.*
!.env.production.example

# Python build artifacts
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environment
.venv/
venv/
env/

# Node / frontend build output (built inside image)
frontend/node_modules/
frontend/dist/
frontend/.next/

# Django collected statics (generated at container start)
backend/staticfiles/
backend/media/
backend/*.log

# Phase 1 raw scraped data (large, regenerable)
phase1/data/raw/

# Phase 2 local vector index (regenerable via build_index.py)
phase2/chroma_db/
phase2/.chromadb/

# Claude Code internal memory / instructions
.claude/
CLAUDE.md
PROGRESS.md
DESIGN_BRIEF.md

# Documentation that does not belong in the image
*.md
!backend/**/*.md

# Developer tooling
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
ui/
mvp.txt

# Docker itself (avoid recursive context)
.docker/

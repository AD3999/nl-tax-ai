# Leave blank in local dev — Vite proxies /api to http://localhost:8000 automatically.
# In production, set to the API origin only (no trailing slash, no /api):
# VITE_API_URL=https://api.taxwijs.nl
VITE_API_URL=

# Google OAuth — get this from Google Cloud Console → Credentials → OAuth 2.0 Client ID
# Authorized JS origins: http://localhost:5173 (dev), https://yourdomain.com (prod)
VITE_GOOGLE_CLIENT_ID=
